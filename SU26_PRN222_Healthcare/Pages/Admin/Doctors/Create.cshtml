@page
@model SU26_PRN222_Healthcare.Pages.Admin.Doctors.CreateModel

@{
    ViewData["Title"] = "Create Doctor";
}

<h1>Create Doctor</h1>

<h4>Doctor</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Doctor.DoctorName" class="control-label"></label>
                <input asp-for="Doctor.DoctorName" class="form-control" />
                <span asp-validation-for="Doctor.DoctorName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Doctor.Specialty" class="control-label"></label>
                <input asp-for="Doctor.Specialty" class="form-control" />
                <span asp-validation-for="Doctor.Specialty" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Doctor.LicenseNumber" class="control-label"></label>
                <input asp-for="Doctor.LicenseNumber" class="form-control" />
                <span asp-validation-for="Doctor.LicenseNumber" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Doctor.MaxPatients" class="control-label"></label>
                <input asp-for="Doctor.MaxPatients" class="form-control" />
                <span asp-validation-for="Doctor.MaxPatients" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Doctor.Active" /> @Html.DisplayNameFor(model => model.Doctor.Active)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
