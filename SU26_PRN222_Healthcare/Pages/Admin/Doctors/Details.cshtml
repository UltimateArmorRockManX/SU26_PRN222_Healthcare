@page "{id:int}"
@model SU26_PRN222_Healthcare.Pages.Admin.Doctors.DetailsModel

@{
    ViewData["Title"] = "Doctor Details";
}

<h1>Doctor Details</h1>

<div>
    <h4>Doctor</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Doctor.DoctorName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Doctor.DoctorName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Doctor.Specialty)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Doctor.Specialty)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Doctor.LicenseNumber)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Doctor.LicenseNumber)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Doctor.MaxPatients)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Doctor.MaxPatients)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Doctor.Active)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Doctor.Active)
        </dd>
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Doctor?.ID">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>
