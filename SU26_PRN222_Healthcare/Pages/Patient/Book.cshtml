@page
@model SU26_PRN222_Healthcare.Pages.Patient.BookModel
@{
    ViewData["Title"] = "Book Appointment";
}

<h1>@ViewData["Title"]</h1>

@if (TempData["success"] != null)
{
    <div class="alert alert-success">@TempData["success"]</div>
}

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-floating">
                <select asp-for="Input.DoctorId" class="form-control" asp-items="Model.DoctorList">
                    <option value="">Select Doctor</option>
                </select>
                <label asp-for="Input.DoctorId" class="form-label">Doctor</label>
            </div>
            <div class="form-floating">
                <input asp-for="Input.AppointmentDate" class="form-control" type="date" />
                <label asp-for="Input.AppointmentDate" class="form-label">Appointment Date</label>
            </div>
            <button type="submit" class="btn btn-primary mt-3">Book</button>
            <a asp-page="./Search" class="btn btn-secondary mt-3 ms-2">Back to Search</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

